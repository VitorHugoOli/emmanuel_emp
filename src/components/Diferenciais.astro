---
import { Icon } from 'astro-icon/components';
import { diferenciais } from '../data/site';
---

<section id="diferenciais" class="bg-tinta text-areia">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
    <div class="max-w-2xl">
      <span class="text-[13px] font-bold uppercase tracking-[0.18em] text-ambar">Por que a Emmanuel</span>
      <h2 class="mt-2 font-display text-[32px] sm:text-[40px] font-semibold tracking-tight text-areia">
        Confiança que se constrói com o tempo
      </h2>
      <p class="mt-3 text-[16px] text-areia/70">
        Números que traduzem o cuidado com cada cliente e cada obra entregue.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
      {
        diferenciais.numeros.map((n) => (
          <div class="reveal">
            <Icon name={`lucide:${n.icone}`} class="h-7 w-7 text-ambar" />
            <p class="mt-4 font-display text-[44px] sm:text-[52px] font-semibold leading-none text-areia">{n.valor}</p>
            <p class="mt-2 text-[15px] text-areia/70">{n.label}</p>
          </div>
        ))
      }
    </div>

    <!-- Faixa de pilares -->
    <div class="mt-12 grid sm:grid-cols-3 gap-4">
      {
        diferenciais.pilares.map((p) => (
          <div class="rounded-2xl bg-white/[0.06] ring-1 ring-white/10 p-5 flex items-start gap-3.5">
            <Icon name={`lucide:${p.icone}`} class="h-5 w-5 text-ambar shrink-0 mt-0.5" />
            <p class="text-[14.5px] text-areia/85">
              <span class="font-semibold text-areia">{p.titulo}</span> {p.texto}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
