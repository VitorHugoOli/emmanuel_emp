---
/**
 * Wordmark tipográfico "Emmanuel Serviços" com ícone de telhado.
 * variant controla as cores para fundo claro (header) ou escuro (rodapé).
 */
interface Props {
  variant?: 'light' | 'dark';
  href?: string;
}
const { variant = 'light', href = '#top' } = Astro.props;

const boxClass = variant === 'dark' ? 'bg-terracota/20 text-ambar' : 'bg-terracota/10 text-terracota';
const nomeClass = variant === 'dark' ? 'text-areia' : 'text-tinta';
const subClass = variant === 'dark' ? 'text-ambar' : 'text-terracota';
---

<a href={href} class="flex items-center gap-2.5 shrink-0" aria-label="Emmanuel Serviços — início">
  <span class={`grid place-items-center h-9 w-9 rounded-xl ${boxClass}`}>
    <svg
      viewBox="0 0 24 24"
      class="h-5 w-5"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M3 11.5 12 4l9 7.5"></path>
      <path d="M5 10.5V20h14v-9.5"></path>
    </svg>
  </span>
  <span class="leading-none">
    <span class={`block font-display text-[19px] font-semibold tracking-tight ${nomeClass}`}>Emmanuel</span>
    <span class={`block text-[11px] font-medium uppercase tracking-[0.22em] -mt-0.5 ${subClass}`}>Serviços</span>
  </span>
</a>
