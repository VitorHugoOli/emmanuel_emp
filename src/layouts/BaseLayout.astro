---
import '../styles/global.css';
import { empresa } from '../data/site';
import { organizationLd, websiteLd, jsonLdGraph } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** og:image — caminho a partir da raiz (ex.: /og/home.png). Default: OG da home. */
  image?: string;
  imageAlt?: string;
  themeColor?: string;
  /** og:type (website | article …). Default: website. */
  ogType?: string;
  /** Impede indexação quando true (ex.: páginas utilitárias). */
  noindex?: boolean;
  /** Nós JSON-LD específicos da página (Product, BreadcrumbList…). */
  jsonld?: object[];
}

const {
  title = 'Emmanuel Serviços — Construção e empreendimentos em Minas Gerais',
  description = 'Emmanuel Serviços: construção civil em Minas Gerais. Empreendimentos próprios, reforma, consultoria, construção, mão de obra e empréstimo de material.',
  image = '/og/home.png',
  imageAlt = empresa.nome,
  themeColor = '#B5532E',
  ogType = 'website',
  noindex = false,
  jsonld = [],
} = Astro.props;

const ogDescription = description;
const ogImage = new URL(image, Astro.site).toString();
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Grafo JSON-LD: Organization + WebSite em todas as páginas + nós da página.
const graph = jsonLdGraph(organizationLd(), websiteLd(), ...jsonld);

// Favicon — símbolo "porta/portal" (Direção B): porta em areia sobre terracota.
const favicon =
  "data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2064%2064'%3E%3Crect%20width='64'%20height='64'%20rx='14'%20fill='%23B5532E'/%3E%3Cpath%20transform='translate(10.24,10.24)%20scale(0.68)'%20fill='%23F5EDE2'%20fill-rule='evenodd'%20d='M20%206%20H44%20Q58%206%2058%2020%20V44%20Q58%2058%2044%2058%20H20%20Q6%2058%206%2044%20V20%20Q6%206%2020%206%20Z%20M24%2050%20V33%20Q24%2022%2032%2022%20Q40%2022%2040%2033%20V50%20Z'/%3E%3C/svg%3E";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph / redes sociais */}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={empresa.nome} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="icon" href={favicon} />

    {/* Dados estruturados (Schema.org) */}
    <script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />

    {/* Google Fonts: Fraunces (display) + Inter (UI) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="bg-areia text-tinta antialiased selection:bg-terracota/20">
    <slot />

    {/* Animação suave de entrada (progressive enhancement) */}
    <script is:inline>
      if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
