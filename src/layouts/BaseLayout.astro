---
import '../styles/global.css';
import { empresa } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Emmanuel Serviços — Construção e empreendimentos em Minas Gerais',
  description = 'Emmanuel Serviços: construção civil em Minas Gerais. Empreendimentos próprios, reforma, consultoria, construção, mão de obra e empréstimo de material.',
} = Astro.props;

const ogDescription =
  'Construímos o lugar que você vai chamar de lar. Empreendimentos próprios e serviços de obra com a confiança de quem constrói lares de verdade.';

// Favicon (telhado em terracota) — SVG data-URI
const favicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23B5532E' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'%3E%3Crect width='24' height='24' rx='5' fill='%23F5EDE2' stroke='none'/%3E%3Cpath d='M4 11.5 12 5l8 6.5'/%3E%3Cpath d='M6 10.5V19h12v-8.5'/%3E%3C/svg%3E";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#B5532E" />

    {/* Open Graph / redes sociais */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={empresa.nome} />

    <link rel="icon" href={favicon} />

    {/* Google Fonts: Fraunces (display) + Inter (UI) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="bg-areia text-tinta antialiased selection:bg-terracota/20">
    <slot />

    {/* Animação suave de entrada (progressive enhancement) */}
    <script is:inline>
      if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
