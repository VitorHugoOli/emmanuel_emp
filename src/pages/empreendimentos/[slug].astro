---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { empresa, whatsappUrl } from '../../data/site';
import { img } from '../../lib/images';
import {
  abs,
  empreendimentoLd,
  residenceLd,
  breadcrumbLd,
} from '../../lib/seo';
import {
  brl,
  m2,
  precoAPartir,
  tipoPlural,
  statusInfo,
  statusUnidade,
  iconePontoInteresse,
  mapsEmbedUrl,
  mapsDirectionsUrl,
} from '../../lib/empreendimento';

export async function getStaticPaths() {
  const items = await getCollection('empreendimentos');
  return items.map((e) => ({ params: { slug: e.id }, props: { e } }));
}

const { e } = Astro.props;
const d = e.data;

const status = statusInfo[d.status];
const rotulo = [tipoPlural[d.tipo] ?? d.tipo, d.localizacao.bairro, d.localizacao.cidade].filter(Boolean).join(' · ');
const precoNum = precoAPartir(d.unidades);
const preco = precoNum != null ? brl.format(precoNum) : null;
const capa = d.galeria[0];
const capaImg = img(capa?.src);
const logoImg = img(d.tema?.logo);
const specs = d.caracteristicas.slice(0, 4);

// --- SEO: OG dinâmico + JSON-LD derivado dos dados do empreendimento ---
const ogImage = `/og/${e.id}.png`;
const ogImageAbs = abs(ogImage);
const jsonld = [
  empreendimentoLd(d, e.id, ogImageAbs),
  residenceLd(d, e.id),
  breadcrumbLd([
    { name: 'Início', url: '/' },
    { name: d.nome, url: `/empreendimentos/${e.id}/` },
  ]),
];

const wa = whatsappUrl(d.contato.mensagem_padrao);
const embedUrl = mapsEmbedUrl(d.localizacao.endereco);
const comoChegar = mapsDirectionsUrl(d.localizacao.endereco);

// Identidade visual do empreendimento (tema) com fallback elegante navy/gold
const primary = d.tema?.cor_primaria ?? '#173A5E';
const gold = d.tema?.cor_secundaria ?? '#B0883E';

const navLinks = [
  { href: '#empreendimento', label: 'O empreendimento' },
  { href: '#plantas', label: 'Plantas' },
  { href: '#localizacao', label: 'Localização' },
  { href: '#unidades', label: 'Unidades' },
];

const themeStyle = [
  `--ld-primary:${primary}`,
  `--ld-gold:${gold}`,
  `--ld-primary-dark:color-mix(in srgb, ${primary} 78%, black)`,
  `--ld-cream:#F3EDE2`,
  `--ld-cream-2:#FBF7F0`,
  `--ld-ink:#1B2A3A`,
  `--ld-ink-sec:#5C6773`,
  `--ld-border:#E3DBCD`,
].join(';');
---

<BaseLayout
  title={d.seo?.titulo ?? `${d.nome} — Emmanuel Serviços`}
  description={d.seo?.descricao ?? d.chamada}
  image={ogImage}
  imageAlt={d.nome}
  themeColor={primary}
  jsonld={jsonld}
>
  <div style={themeStyle} class="bg-[var(--ld-cream)] text-[var(--ld-ink)]">
    <!-- ============================= HEADER ============================= -->
    <header class="fixed top-0 inset-x-0 z-50 bg-[var(--ld-cream-2)]/90 backdrop-blur-md border-b border-[var(--ld-border)]">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 flex h-[68px] items-center justify-between gap-4">
        <a href="#topo" class="flex items-center gap-3 shrink-0" aria-label={`${d.nome} — início`}>
          {
            logoImg ? (
              <Image src={logoImg} alt={d.nome} height={40} class="h-10 w-auto" />
            ) : (
              <span class="font-display text-[20px] font-semibold text-[var(--ld-primary)]">{d.nome}</span>
            )
          }
        </a>

        <nav class="hidden lg:flex items-center gap-7 text-[14.5px] font-medium text-[var(--ld-ink-sec)]" aria-label="Seções">
          {navLinks.map((l) => <a href={l.href} class="hover:text-[var(--ld-primary)] transition-colors">{l.label}</a>)}
        </nav>

        <div class="flex items-center gap-2">
          <a href="/" class="hidden sm:inline-flex items-center gap-1.5 text-[13.5px] font-medium text-[var(--ld-ink-sec)] hover:text-[var(--ld-primary)] transition-colors">
            <Icon name="lucide:arrow-left" class="h-4 w-4" /> Emmanuel
          </a>
          <a
            href={wa}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full bg-[var(--ld-primary)] px-4 py-2.5 text-[14px] font-semibold text-white hover:bg-[var(--ld-primary-dark)] transition-colors"
          >
            <Icon name="lucide:message-circle" class="h-4 w-4" /> <span class="hidden sm:inline">Tenho interesse</span><span class="sm:hidden">WhatsApp</span>
          </a>
        </div>
      </div>
    </header>

    <main id="topo">
      <!-- ============================= HERO / CAPA ============================= -->
      <section class="relative min-h-[88vh] flex items-end overflow-hidden">
        {
          capaImg ? (
            <Image
              src={capaImg}
              alt={capa.alt}
              widths={[768, 1280, 1920]}
              sizes="100vw"
              class="absolute inset-0 h-full w-full object-cover"
            />
          ) : (
            capa && <img src={capa.src} alt={capa.alt} class="absolute inset-0 h-full w-full object-cover" />
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--ld-primary)]/95 via-[var(--ld-primary)]/55 to-[var(--ld-primary)]/20"></div>

        <div class="relative mx-auto max-w-6xl px-4 sm:px-6 w-full pb-12 sm:pb-16 pt-28">
          {
            status && (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--ld-gold)] text-[var(--ld-ink)] px-3.5 py-1.5 text-[13px] font-bold">
                <Icon name={`lucide:${status.icone}`} class="h-4 w-4" />
                {status.label}
              </span>
            )
          }
          <p class="mt-4 text-[13px] font-semibold uppercase tracking-[0.18em] text-white/80">{rotulo}</p>
          <h1 class="mt-2 font-display text-[40px] leading-[1.04] sm:text-[58px] lg:text-[68px] font-semibold tracking-tight text-white max-w-3xl">
            {d.nome}
          </h1>
          <p class="mt-4 text-[17px] sm:text-[19px] leading-relaxed text-white/90 max-w-2xl">{d.chamada}</p>

          <!-- specs rápidas -->
          <div class="mt-7 flex flex-wrap gap-2.5">
            {
              specs.map((s) => (
                <span class="inline-flex items-center gap-2 rounded-full bg-white/15 ring-1 ring-white/25 backdrop-blur px-3.5 py-2 text-[14px] font-medium text-white">
                  <Icon name={`lucide:${s.icone ?? 'check'}`} class="h-[18px] w-[18px] text-[var(--ld-gold)]" />
                  {s.texto}
                </span>
              ))
            }
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a
              href={wa}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[var(--ld-gold)] px-6 py-3.5 text-[15px] font-semibold text-[var(--ld-ink)] hover:brightness-95 transition"
            >
              <Icon name="lucide:message-circle" class="h-5 w-5" /> Falar com um consultor
            </a>
            <a
              href="#unidades"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-white/10 ring-1 ring-white/40 px-6 py-3.5 text-[15px] font-semibold text-white hover:bg-white/20 transition"
            >
              Ver unidades e valores <Icon name="lucide:arrow-down" class="h-5 w-5" />
            </a>
          </div>

          {
            d.previsao_entrega && (
              <p class="mt-6 inline-flex items-center gap-2 text-[14px] text-white/85">
                <Icon name="lucide:calendar-clock" class="h-4 w-4 text-[var(--ld-gold)]" />
                {d.previsao_entrega}
              </p>
            )
          }
        </div>
      </section>

      <!-- ============================= O EMPREENDIMENTO ============================= -->
      <section id="empreendimento" class="bg-[var(--ld-cream-2)]">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20 grid lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-14 items-start">
          <div class="reveal">
            <span class="text-[13px] font-bold uppercase tracking-[0.18em] text-[var(--ld-gold)]">O empreendimento</span>
            <h2 class="mt-2 font-display text-[30px] sm:text-[38px] font-semibold tracking-tight text-[var(--ld-primary)]">
              Pensado para quem quer morar bem
            </h2>
            {d.descricao.split('\n').filter(Boolean).map((p) => (
              <p class="mt-4 text-[16px] leading-relaxed text-[var(--ld-ink-sec)]">{p}</p>
            ))}
          </div>

          <div class="reveal grid grid-cols-2 gap-3.5">
            {
              d.caracteristicas.map((c) => (
                <div class="flex items-start gap-3 rounded-2xl bg-white p-4 ring-1 ring-[var(--ld-border)]">
                  <span class="grid place-items-center h-10 w-10 shrink-0 rounded-xl bg-[var(--ld-primary)]/8 text-[var(--ld-primary)]">
                    <Icon name={`lucide:${c.icone ?? 'check'}`} class="h-5 w-5" />
                  </span>
                  <span class="text-[14.5px] font-medium leading-snug self-center">{c.texto}</span>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ============================= PLANTAS ============================= -->
      {
        d.plantas.length > 0 && (
          <section id="plantas" class="bg-[var(--ld-cream)]">
            <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
              <div class="max-w-2xl">
                <span class="text-[13px] font-bold uppercase tracking-[0.18em] text-[var(--ld-gold)]">Plantas</span>
                <h2 class="mt-2 font-display text-[30px] sm:text-[38px] font-semibold tracking-tight text-[var(--ld-primary)]">
                  Plantas dos pavimentos
                </h2>
                <p class="mt-3 text-[16px] text-[var(--ld-ink-sec)]">
                  Clique para ampliar. Imagens ilustrativas — podem sofrer alterações no desenvolvimento do projeto.
                </p>
              </div>

              <div class="mt-10 grid sm:grid-cols-2 gap-6">
                {
                  d.plantas.map((p) => {
                    const plantaImg = img(p.imagem);
                    return (
                    <figure class="reveal group bg-white rounded-3xl overflow-hidden ring-1 ring-[var(--ld-border)]">
                      {plantaImg && (
                        <a href={plantaImg.src} target="_blank" rel="noopener" class="block relative bg-white">
                          <Image src={plantaImg} alt={`Planta ${p.nome}`} loading="lazy" class="w-full h-auto" />
                          <span class="absolute top-3 right-3 inline-flex items-center gap-1.5 rounded-full bg-[var(--ld-primary)]/85 text-white px-3 py-1.5 text-[12px] font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
                            <Icon name="lucide:maximize-2" class="h-3.5 w-3.5" /> Ampliar
                          </span>
                        </a>
                      )}
                      <figcaption class="flex items-center justify-between gap-3 px-5 py-4 border-t border-[var(--ld-border)]">
                        <span class="font-display text-[18px] font-semibold text-[var(--ld-primary)]">{p.nome}</span>
                        <span class="text-[13.5px] font-medium text-[var(--ld-ink-sec)]">{m2(p.area_m2)}</span>
                      </figcaption>
                    </figure>
                    );
                  })
                }
              </div>
            </div>
          </section>
        )
      }

      <!-- ============================= LOCALIZAÇÃO ============================= -->
      <section id="localizacao" class="bg-[var(--ld-cream-2)]">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
          <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-start">
            <div class="reveal">
              <span class="text-[13px] font-bold uppercase tracking-[0.18em] text-[var(--ld-gold)]">Localização</span>
              <h2 class="mt-2 font-display text-[30px] sm:text-[38px] font-semibold tracking-tight text-[var(--ld-primary)]">
                Perto de tudo o que importa
              </h2>
              <p class="mt-3 inline-flex items-start gap-2 text-[16px] text-[var(--ld-ink-sec)]">
                <Icon name="lucide:map-pin" class="h-5 w-5 shrink-0 mt-0.5 text-[var(--ld-primary)]" />
                {d.localizacao.endereco}
              </p>

              {
                d.localizacao.pontos_de_interesse.length > 0 && (
                  <ul class="mt-7 grid sm:grid-cols-2 gap-x-6 gap-y-3.5">
                    {d.localizacao.pontos_de_interesse.map((pt) => (
                      <li class="flex items-center gap-3 text-[14.5px]">
                        <span class="grid place-items-center h-9 w-9 shrink-0 rounded-xl bg-[var(--ld-primary)]/8 text-[var(--ld-primary)]">
                          <Icon name={`lucide:${iconePontoInteresse[pt.tipo] ?? 'map-pin'}`} class="h-[18px] w-[18px]" />
                        </span>
                        <span>
                          <span class="font-medium">{pt.nome}</span>
                          {pt.distancia && <span class="text-[var(--ld-ink-sec)]"> · {pt.distancia}</span>}
                        </span>
                      </li>
                    ))}
                  </ul>
                )
              }

              <a
                href={comoChegar}
                target="_blank"
                rel="noopener"
                class="mt-8 inline-flex items-center gap-2 rounded-full bg-[var(--ld-primary)] px-5 py-3 text-[15px] font-semibold text-white hover:bg-[var(--ld-primary-dark)] transition-colors"
              >
                <Icon name="lucide:navigation" class="h-[18px] w-[18px]" /> Como chegar
              </a>
            </div>

            <div class="reveal rounded-3xl overflow-hidden ring-1 ring-[var(--ld-border)] shadow-sm">
              <iframe
                title={`Mapa — ${d.nome}`}
                src={embedUrl}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="w-full h-[340px] sm:h-[460px] border-0"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================= UNIDADES / TABELA ============================= -->
      {
        d.unidades.length > 0 && (
          <section id="unidades" class="bg-[var(--ld-primary)] text-white">
            <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
              <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5">
                <div class="max-w-xl">
                  <span class="text-[13px] font-bold uppercase tracking-[0.18em] text-[var(--ld-gold)]">Unidades</span>
                  <h2 class="mt-2 font-display text-[30px] sm:text-[38px] font-semibold tracking-tight">
                    Disponibilidade e valores
                  </h2>
                  <p class="mt-3 text-[15px] text-white/70">
                    Entrada parcelada + financiamento bancário. Valores e disponibilidade sujeitos a alteração.
                  </p>
                </div>
                {
                  preco && (
                    <div class="shrink-0 rounded-2xl bg-white/10 ring-1 ring-white/20 px-6 py-4">
                      <p class="text-[13px] text-white/70">A partir de</p>
                      <p class="font-display text-[30px] font-semibold leading-none text-[var(--ld-gold)]">{preco}</p>
                    </div>
                  )
                }
              </div>

              <div class="mt-9 overflow-x-auto rounded-2xl ring-1 ring-white/15">
                <table class="w-full min-w-[680px] text-left text-[14.5px]">
                  <thead class="bg-white/10 text-white/80 text-[12.5px] uppercase tracking-wide">
                    <tr>
                      <th class="px-4 py-3.5 font-semibold">Unidade</th>
                      <th class="px-4 py-3.5 font-semibold">Área</th>
                      <th class="px-4 py-3.5 font-semibold">Suíte</th>
                      <th class="px-4 py-3.5 font-semibold">Entrada</th>
                      <th class="px-4 py-3.5 font-semibold">Financiamento</th>
                      <th class="px-4 py-3.5 font-semibold">Valor total</th>
                      <th class="px-4 py-3.5 font-semibold">Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {
                      d.unidades.map((u) => {
                        const su = statusUnidade[u.status];
                        const vendido = u.status === 'vendido';
                        return (
                          <tr class={`border-t border-white/10 ${vendido ? 'text-white/45' : ''}`}>
                            <td class="px-4 py-3.5 font-semibold whitespace-nowrap">{u.identificacao}</td>
                            <td class="px-4 py-3.5 whitespace-nowrap">{m2(u.area_m2)}</td>
                            <td class="px-4 py-3.5">{u.suite ? 'Sim' : '—'}</td>
                            <td class="px-4 py-3.5 whitespace-nowrap">
                              {u.entrada != null
                                ? `${u.entrada_parcelas ?? 1}× ${brl.format(u.entrada)}`
                                : '—'}
                            </td>
                            <td class="px-4 py-3.5 whitespace-nowrap">
                              {u.financiamento != null ? brl.format(u.financiamento) : '—'}
                            </td>
                            <td class="px-4 py-3.5 whitespace-nowrap font-semibold">
                              {u.preco != null ? brl.format(u.preco) : '—'}
                            </td>
                            <td class="px-4 py-3.5">
                              <span
                                class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[12.5px] font-semibold ${
                                  su.classe === 'disponivel'
                                    ? 'bg-[var(--ld-gold)] text-[var(--ld-ink)]'
                                    : su.classe === 'reservado'
                                      ? 'bg-white/20 text-white'
                                      : 'bg-white/10 text-white/50'
                                }`}
                              >
                                {su.label}
                              </span>
                            </td>
                          </tr>
                        );
                      })
                    }
                  </tbody>
                </table>
              </div>
              <p class="mt-3 text-[13px] text-white/60">
                * Entrega das chaves na assinatura do financiamento. Consulte condições e parcelamento da entrada.
              </p>

              <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3 text-center">
                <a
                  href={wa}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-[var(--ld-gold)] px-7 py-4 text-[16px] font-semibold text-[var(--ld-ink)] hover:brightness-95 transition"
                >
                  <Icon name="lucide:message-circle" class="h-5 w-5" /> Quero reservar minha unidade
                </a>
              </div>
            </div>
          </section>
        )
      }
    </main>

    <!-- ============================= RODAPÉ ============================= -->
    <footer class="bg-[var(--ld-cream-2)] border-t border-[var(--ld-border)]">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-6 text-center sm:text-left">
        <div>
          <p class="text-[13px] uppercase tracking-[0.18em] text-[var(--ld-ink-sec)]">Realização</p>
          <a href="/" class="font-display text-[22px] font-semibold text-[var(--ld-primary)] hover:opacity-80 transition-opacity">
            {empresa.nome}
          </a>
          <p class="mt-1 text-[13px] text-[var(--ld-ink-sec)]">CNPJ: {empresa.cnpj}</p>
        </div>
        <div class="flex items-center gap-3">
          <a href="/" class="inline-flex items-center gap-2 rounded-full ring-1 ring-[var(--ld-border)] px-5 py-3 text-[14.5px] font-semibold text-[var(--ld-ink)] hover:bg-[var(--ld-cream)] transition-colors">
            <Icon name="lucide:arrow-left" class="h-4 w-4" /> Voltar ao site
          </a>
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-[var(--ld-primary)] px-5 py-3 text-[14.5px] font-semibold text-white hover:bg-[var(--ld-primary-dark)] transition-colors">
            <Icon name="lucide:message-circle" class="h-4 w-4" /> {empresa.whatsappDisplay.replace('+55 ', '')}
          </a>
        </div>
      </div>
    </footer>

    <!-- Botão flutuante WhatsApp (mensagem contextual) -->
    <a
      href={wa}
      target="_blank"
      rel="noopener"
      class="fixed bottom-5 right-5 z-50 inline-flex items-center gap-2.5 rounded-full bg-[#25D366] pl-4 pr-5 py-3.5 text-white font-semibold shadow-lg hover:bg-[#1FAF52] transition-colors"
      aria-label="Falar no WhatsApp"
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true">
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
        ></path>
      </svg>
      <span class="hidden sm:inline text-[15px]">Fale conosco</span>
    </a>
  </div>
</BaseLayout>
